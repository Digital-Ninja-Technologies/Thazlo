---
interface Props {
  label: string
}

const { label } = Astro.props
---

<div class="flex flex-col items-center space-y-4 text-center max-w-3xl mx-auto">
  <h3 class="text-lg font-medium tracking-wide text-primary uppercase">
    {label}
  </h3>
  <h2 class="section-title">
    <slot />
  </h2>
</div>
