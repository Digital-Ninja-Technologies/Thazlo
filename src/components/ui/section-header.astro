---
interface Props {
  label: string
}

const { label } = Astro.props
---

<div class="mx-auto flex max-w-4xl flex-col items-center space-y-4 text-center">
  <h3
    class="text-lg font-medium tracking-wide text-primary uppercase opacity-0"
    data-animate="animate-fade-in-down"
  >
    {label}
  </h3>
  <h2
    class="section-title opacity-0"
    data-animate="animate-fade-in-up animate-delay-150"
  >
    <slot />
  </h2>
</div>
