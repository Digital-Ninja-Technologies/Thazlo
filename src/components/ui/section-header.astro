---
interface Props {
  label: string
}

const { label } = Astro.props
---

<div class="mx-auto flex max-w-4xl flex-col items-center space-y-4 text-center">
  <p class="text-lg font-medium tracking-wide text-primary uppercase">
    {label}
  </p>
  <h2 class="section-title">
    <slot />
  </h2>
</div>
