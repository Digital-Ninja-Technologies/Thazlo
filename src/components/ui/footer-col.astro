---
import { cn } from "@/lib/utils"

interface Props {
  title: string
  class?: string
}

const { title, class: className = "text-white" } = Astro.props
---

<div class="flex flex-col gap-4">
  <h3 class={cn("font-bold font-heading", className)}>{title}</h3>
  <ul class="flex flex-col gap-3">
    <slot />
  </ul>
</div>
