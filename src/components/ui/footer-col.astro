---
import { cn } from "@/lib/utils"

interface Props {
  title: string
  class?: string
}

const { title, class: className = "text-white" } = Astro.props
---

<div class="flex flex-col gap-4">
  <h4 class={cn("font-bold", className)}>{title}</h4>
  <ul class="flex flex-col gap-3">
    <slot />
  </ul>
</div>
