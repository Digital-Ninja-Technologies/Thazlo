---
import { cn } from "@/lib/utils"
import { Image } from "astro:assets"

interface Props {
  className?: string
  iconClass?: string
  variant?: "icon" | "full"
}

const { className = "text-primary", iconClass, variant = "full" } = Astro.props
---

<a href="/" class="group block w-fit rounded-md outline-none">
  <div class={cn("flex items-center gap-2", className)}>
    <Image
      src="/logo.svg"
      priority
      loading="eager"
      alt="T-HAZLO's Logo"
      height="45"
      width="45"
      class={iconClass}
    />

    {
      variant === "full" && (
        <span class="mt-1 font-sans text-xl font-extrabold tracking-tight">
          T HAZLO
        </span>
      )
    }
  </div>
</a>
