---
import Instagram from "@/assets/icon/instagram.svg"
import Facebook from "@/assets/icon/facebook.svg"
import Linkedin from "@/assets/icon/linkedin.svg"
import X from "@/assets/icon/twitter-x.svg"

import { siteConfig } from "@/config/site"
import Logo from "@/components/global/Logo.astro"
import { ThemeToggle } from "./ThemeToggle"
import FooterCol from "@/components/ui/footer-col.astro"
import { StoreButton } from "@/components/ui/store-button"

const currentYear = new Date().getFullYear()

const socialIcons = {
  facebook: Facebook,
  instagram: Instagram,
  linkedin: Linkedin,
  x: X
} as const

const socialLinks = Object.entries(siteConfig.socials)
  .filter(([platform, url]) => platform !== "whatsapp" && (!url || url !== "#"))
  .map(([platform, url]) => ({
    platform,
    url,
    Icon: socialIcons[platform as keyof typeof socialIcons],
  }))

const contactDetails = siteConfig.contact

const LocationIcon = contactDetails.location.icon
const EmailIcon = contactDetails.emails[0].icon
const PhoneIcon = contactDetails.phone.icon
---

<footer
  class="mt-auto border-t border-primary bg-primary pt-16 pb-8 text-white"
>
  <div class="mx-auto max-w-7xl px-4 md:px-8 lg:px-12">
    {/* MAIN FOOTER LINKS */}
    <div class="mb-16 grid grid-cols-2 gap-6 md:grid-cols-4 lg:grid-cols-7">
      {/* Brand & Bio */}
      <div class="col-span-2 lg:col-span-2">
        <div class="mb-4">
          <Logo
            variant="full"
            className="flex-col items-center gap-2 text-white"
            iconClass="brightness-0 invert"
          />
        </div>

        <p class="mb-4 max-w-sm leading-relaxed text-white/80">
          Essential home services across Nigeria Gas, laundry, and more, all in
          one app.
        </p>

        <div class="mb-6 flex flex-wrap gap-2 md:flex-nowrap">
          <StoreButton
            platform="apple"
            storeVariant="outline"
            className="px-2! text-sm!"
          />
          <StoreButton
            platform="google"
            storeVariant="outline"
            className="px-2! text-sm!"
          />
        </div>

        {/* Social Icons */}
        <div class="flex gap-4">
          {
            socialLinks.map(({ platform, url, Icon }) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-full border border-white/20 bg-white/5 p-2 text-white/80 transition-all duration-300 outline-none hover:scale-110 hover:bg-white/20 hover:text-white focus-visible:ring-2 focus-visible:ring-white"
                aria-label={`Follow THazlo on ${platform}`}
              >
                <Icon class="size-5" />
              </a>
            ))
          }
        </div>
      </div>

      {
        siteConfig.footerNav.map((section) => (
          <FooterCol title={section.title}>
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="group link w-fit text-white/80 hover:text-white"
                >
                  <span class="h-px w-0 bg-white transition-all duration-300 group-hover:w-3" />
                  {link.name}
                </a>
              </li>
            ))}
          </FooterCol>
        ))
      }

      <div class="col-span-2">
        <FooterCol title="Get in Touch" class="text-white">
          <li>
            <a
              href={contactDetails.location.link}
              class="group link gap-3 text-white/80 hover:text-white"
            >
              <LocationIcon
                class="size-5 transition-colors group-hover:text-white"
              />
              {contactDetails.location.value}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${contactDetails.emails[0].value}`}
              class="group link gap-3 text-white/80 hover:text-white"
            >
              <EmailIcon
                class="size-5 transition-colors group-hover:text-white"
              />
              {contactDetails.emails[0].value}
            </a>
          </li>
          <li>
            <a
              href={`tel:${contactDetails.phone.value}`}
              class="group link gap-3 text-white/80 hover:text-white"
            >
              <PhoneIcon
                class="size-5 transition-colors group-hover:text-white"
              />
              {contactDetails.phone.value}
            </a>
          </li>
        </FooterCol>
      </div>
    </div>

    {/* BOTTOM BAR */}
    <div
      class="flex flex-col items-center justify-center gap-4 border-t border-white/20 pt-8 text-sm text-white/80 md:flex-row"
    >
      <p class="text-center">
        &copy; {currentYear}{" "}
        {siteConfig.name} Innovations Limited. All rights reserved.
      </p>
    </div>
  </div>

  <ThemeToggle client:only="react">
    <div
      slot="fallback"
      class="fixed right-6 bottom-6 z-60 size-10 animate-pulse rounded-full border border-border bg-background shadow-lg md:right-8 md:bottom-8"
    >
    </div>
  </ThemeToggle>
</footer>
