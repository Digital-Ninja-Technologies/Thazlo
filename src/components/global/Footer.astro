---
import Instagram from "@/assets/icons/instagram.svg"
import Facebook from "@/assets/icons/facebook.svg"
import Linkedin from "@/assets/icons/linkedin.svg"

import { siteConfig } from "@/config/site"
import Logo from "@/components/global/Logo.astro"
import { ThemeToggle } from "./ThemeToggle"
import FooterCol from "@/components/ui/footer-col.astro"

const currentYear = new Date().getFullYear()

const socialIcons = {
  facebook: Facebook,
  instagram: Instagram,
  linkedin: Linkedin,
} as const

const socialLinks = Object.entries(siteConfig.socials).map(
  ([platform, url]) => ({
    platform,
    url,
    Icon: socialIcons[platform as keyof typeof socialIcons],
  })
)
---

<footer class="mt-auto border-t border-border/40 bg-background pt-16 pb-8">
  <div class="mx-auto max-w-7xl px-4 md:px-8 lg:px-12">
    {/* MAIN FOOTER LINKS */}
    <div class="mb-16 grid grid-cols-2 gap-10 md:grid-cols-4 lg:grid-cols-6">
      {/* Column 1: Brand & Bio */}
      <div class="col-span-2 lg:col-span-2">
        <div class="mb-4">
          <!-- <Logo variant="full" className="flex-col" iconClass="invert brightness-0" /> -->
          <Logo variant="full" />
        </div>
        <p class="mb-6 max-w-sm leading-relaxed text-muted-foreground">
          {siteConfig.description}
        </p>

        {/* Social Icons */}
        <div class="flex gap-4">
          {
            socialLinks.map(({ platform, url, Icon }) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-full border border-border/50 bg-secondary p-2 text-muted-foreground transition-all duration-300 outline-none hover:scale-110 hover:bg-primary/10 hover:text-primary focus-visible:ring-2 focus-visible:ring-ring"
                aria-label={`Follow Ventix on ${platform}`}
              >
                <Icon class="size-5" />
              </a>
            ))
          }
        </div>
      </div>

      {
        siteConfig.footerNav.map((section) => (
          <FooterCol title={section.title}>
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="group flex w-fit items-center gap-2 rounded-sm text-muted-foreground transition-colors outline-none hover:text-primary focus-visible:ring-2 focus-visible:ring-ring"
                >
                  <span class="h-px w-0 bg-primary transition-all duration-300 group-hover:w-3" />
                  {link.name}
                </a>
              </li>
            ))}
          </FooterCol>
        ))
      }
      <FooterCol title="Get in Touch">
        {
          // <li>  </li>
        }
      </FooterCol>
    </div>

    {/* BOTTOM BAR */}
    <div
      class="flex flex-col items-center justify-between gap-4 border-t border-border/40 pt-8 text-sm text-muted-foreground md:flex-row"
    >
      <p>&copy; {currentYear} {siteConfig.name} Inc. All rights reserved.</p>

      <ThemeToggle client:only="react">
        <div
          slot="fallback"
          class="h-9 w-26 animate-pulse rounded-full border border-border/50 bg-secondary/50"
        >
        </div>
      </ThemeToggle>
    </div>
  </div>
</footer>
