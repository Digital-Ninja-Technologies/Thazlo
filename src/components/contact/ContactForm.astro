---
import { Input } from "@/components/ui/input"
import { Label } from "@/components/ui/label"
import { Button } from "../ui/button"
import { Textarea } from "../ui/textarea"
---

<div
  data-aos="fade-up"
  data-aos-delay="280"
  class="section-bg rounded-3xl p-6 py-12 md:p-12"
>
  <h2
    class="mb-3 text-2xl font-bold tracking-tight text-foreground md:text-4xl"
  >
    Send Us a Message
  </h2>
  <p class="mb-10 text-lg leading-relaxed text-muted-foreground">
    Whether you have a question, suggestion, or need quick support, simply fill
    out the form below and our team will get back to you as soon as possible.
  </p>

  <form
    id="contact-form"
    action="https://formspree.io/f/xaqgqvgl"
    method="POST"
    class="flex flex-col gap-6"
    novalidate
  >
    <div class="space-y-3">
      <Label htmlFor="name">Full Name</Label>
      <Input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Enter your full name"
      />
    </div>

    <div class="space-y-3">
      <Label htmlFor="email">Email Address</Label>
      <Input
        type="email"
        id="email"
        name="email"
        required
        placeholder="Enter your email address"
      />

      <div class="flex gap-2 pt-1">
        <button
          role="button"
          type="button"
          id="gmail-chip"
          class="rounded-full border border-border/50 bg-background px-4 py-1.5 text-xs font-medium text-muted-foreground transition-colors hover:bg-border/50"
        >
          @gmail.com
        </button>
      </div>
    </div>

    <div class="space-y-3">
      <Label htmlFor="message">Message</Label>
      <Textarea
        id="message"
        name="message"
        required
        rows={5}
        placeholder="Tell us more about your request or concern"
        className="min-h-28 w-full resize-none placeholder:text-muted-foreground/70"
      />
    </div>

    <Button
      type="submit"
      id="submit-btn"
      className="mt-4 h-10 shadow-lg shadow-primary/20"
    >
      <span id="btn-text">Send Message</span>
      <svg
        id="btn-spinner"
        class="hidden size-6 animate-spin text-white"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
      >
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"></circle>
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path>
      </svg>
    </Button>

    <div
      id="form-status"
      class="hidden text-center text-sm font-medium"
      aria-live="polite"
    >
    </div>
  </form>
</div>

<script>
  const setupContactForm = () => {
    const form = document.getElementById("contact-form") as HTMLFormElement
    const btn = document.getElementById("submit-btn") as HTMLButtonElement
    const btnText = document.getElementById("btn-text")
    const btnSpinner = document.getElementById("btn-spinner")
    const formStatus = document.getElementById("form-status")
    const emailInput = document.getElementById("email") as HTMLInputElement
    const gmailChip = document.getElementById("gmail-chip") as HTMLButtonElement

    if (!form || form.dataset.initialized === "true") return

    form.dataset.initialized = "true"

    if (gmailChip && emailInput) {
      gmailChip.addEventListener("click", () => {
        const currentVal = emailInput.value.trim()
        if (currentVal && !currentVal.includes("@")) {
          emailInput.value = currentVal + "@gmail.com"
        }
        emailInput.focus()
      })
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault()

      if (!form.checkValidity()) {
        form.reportValidity()
        return
      }

      btn.disabled = true
      if (btnText) btnText.classList.add("hidden")
      if (btnSpinner) btnSpinner.classList.remove("hidden")
      if (formStatus) {
        formStatus.className = "hidden mt-2 text-center text-sm font-medium"
        formStatus.textContent = ""
      }

      try {
        const formData = new FormData(form)

        const endpoint = form.action

        const response = await fetch(endpoint, {
          method: "POST",
          body: formData,
          headers: {
            Accept: "application/json",
          },
        })

        if (!response.ok) {
          throw new Error("Failed to send message")
        }

        form.reset()
        if (formStatus) {
          formStatus.textContent =
            "Message sent successfully! We will get back to you soon."
          formStatus.classList.remove("hidden")
          formStatus.classList.add("text-green-600", "dark:text-green-400")
        }
      } catch (error) {
        if (formStatus) {
          formStatus.textContent = "Something went wrong. Please try again."
          formStatus.classList.remove("hidden")
          formStatus.classList.add("text-red-600", "dark:text-red-400")
        }
      } finally {
        btn.disabled = false
        if (btnText) btnText.classList.remove("hidden")
        if (btnSpinner) btnSpinner.classList.add("hidden")
      }
    })
  }

  setupContactForm()

  document.addEventListener("astro:page-load", setupContactForm)
</script>
