---
import SectionHeader from "@/components/ui/section-header.astro"
import { StoreButton } from "@/components/ui/store-button"
import QrScanner from "@/components/download/QrScanner.astro"
---

<section class="section-wrapper pt-36 md:pt-40">
  <div class="flex flex-col items-center justify-center space-y-6 text-center">
    <SectionHeader label="FREE TO DOWNLOAD">
      Get the <span class="text-primary">Thazlo app</span>
    </SectionHeader>

    <p class="section-description max-w-xl text-center">
      Gas refills and laundry care managed from your pocket. Join thousands of
      Nigerian households already living easier.
    </p>

    {/* CTAs */}
    <div class="flex flex-wrap justify-center gap-4">
      <StoreButton platform="google" storeVariant="dark" />
      <StoreButton platform="apple" storeVariant="dark" />
    </div>

    {/* QR code section */}
    <div class="mt-8 w-full max-w-md">
      <QrScanner />
      <!-- <QrScanner appleQr="/images/apple-qr.png" googleQr="/images/google-qr.png" /> -->
    </div>
  </div>
</section>
