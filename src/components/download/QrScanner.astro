---
import { siteConfig } from "@/config/site"
interface Props {
  appleQr?: string
  googleQr?: string
}

const {
  appleQr = `https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${siteConfig.appLink.apple}`,
  googleQr = `https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${siteConfig.appLink.google}`,
} = Astro.props
---

<div class="flex flex-col items-center justify-center space-y-8">
  <p
    class="text-lg font-medium tracking-widest text-foreground uppercase"
    data-aos="fade-right"
    data-aos-delay="380"
  >
    OR
  </p>

  <h3
    class="text-2xl font-medium text-foreground"
    data-aos="fade-up"
    data-aos-delay="380"
  >
    Scan to download app
  </h3>

  <div
    class="relative flex size-40 items-center justify-center rounded-3xl p-4 transition-transform duration-300 hover:scale-105"
  >
    {/* Loading Overlay */}
    <div
      id="qr-loader"
      class="absolute top-1/2 hidden left-1/2 z-10 -translate-x-1/2 -translate-y-1/2 flex-col items-center justify-center rounded-3xl bg-background/80 backdrop-blur-sm"
    >
      <div
        class="size-6 animate-spin rounded-full border-2 border-primary border-t-transparent"
      >
      </div>
    </div>

    {/* QR Image */}
    <img
      id="qr-code-image"
      src={appleQr}
      alt="Scan to download"
      class="size-full object-contain transition-opacity duration-300 dark:invert"
      data-apple={appleQr}
      data-google={googleQr}
      loading="eager"
      data-aos="zoom-in"
      data-aos-delay="200"
    />
  </div>

  <div
    class="inline-flex items-center rounded-full border border-border/50 bg-background p-1.5 shadow-sm"
    data-aos="fade-up"
    data-aos-delay="280"
  >
    <button
      id="qr-btn-apple"
      class="rounded-full bg-primary px-6 py-2 text-sm font-medium text-white transition-colors"
    >
      App Store
    </button>
    <button
      id="qr-btn-google"
      class="rounded-full bg-transparent px-6 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
    >
      Play store
    </button>
  </div>
</div>

<script>
  const setupQrToggle = () => {
    const btnApple = document.getElementById("qr-btn-apple")
    const btnGoogle = document.getElementById("qr-btn-google")
    const qrImage = document.getElementById("qr-code-image") as HTMLImageElement
    const qrLoader = document.getElementById("qr-loader")

    if (!btnApple || !btnGoogle || !qrImage || !qrLoader) return

    const appleSrc = qrImage.dataset.apple
    const googleSrc = qrImage.dataset.google

    // Hide loader when the image finishes loading
    qrImage.addEventListener("load", () => {
      qrLoader.classList.add("hidden")
      qrImage.classList.remove("opacity-0")
    })

    const setActive = (platform: "apple" | "google") => {
      const targetSrc = platform === "apple" ? appleSrc : googleSrc

      // Prevent unnecessary network requests and loading states
      if (qrImage.src === targetSrc) return

      // Trigger loading state
      qrLoader.classList.remove("hidden")
      qrImage.classList.add("opacity-0")

      if (platform === "apple") {
        btnApple.className =
          "rounded-full bg-primary px-6 py-2 text-sm font-medium text-white transition-colors"
        btnGoogle.className =
          "rounded-full bg-transparent px-6 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
        if (appleSrc) qrImage.src = appleSrc
      } else {
        btnGoogle.className =
          "rounded-full bg-primary px-6 py-2 text-sm font-medium text-white transition-colors"
        btnApple.className =
          "rounded-full bg-transparent px-6 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
        if (googleSrc) qrImage.src = googleSrc
      }
    }

    btnApple.addEventListener("click", () => setActive("apple"))
    btnGoogle.addEventListener("click", () => setActive("google"))
  }

  setupQrToggle()
  document.addEventListener("astro:after-swap", setupQrToggle)
</script>
