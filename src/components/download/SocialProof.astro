---
import { Star } from "@lucide/astro"
---

<section class="section-wrapper mx-w-5xl mx-auto py-24">
  <div
    class="flex flex-col items-center justify-center gap-6 sm:flex-row md:gap-8"
  >
    {/* avatar stack */}
    <div class="relative h-14 w-28 shrink-0">
      <div
        data-aos="zoom-in"
        data-aos-delay="200"
        class="absolute top-0 left-0 z-20 flex size-11 items-center justify-center rounded-full bg-black text-base font-bold text-white dark:bg-white dark:text-black"
      >
        AB
      </div>
      <div
        data-aos="zoom-in"
        data-aos-delay="300"
        class="absolute -top-7 left-7 z-10 flex size-11 items-center justify-center rounded-full bg-[#4BD4FA] text-base font-bold text-black"
      >
        YB
      </div>
      <div
        data-aos="zoom-in"
        data-aos-delay="400"
        class="absolute top-0 left-14 z-20 flex size-11 items-center justify-center rounded-full bg-[#4CAF50] text-base font-bold text-black"
      >
        SB
      </div>
    </div>

    <div class="flex flex-col text-center sm:text-left">
      {/* Stars */}
      <div
        class="mb-2 flex justify-center gap-1 sm:justify-start"
        data-aos="fade-left"
        data-aos-delay="200"
      >
        {
          Array.from({ length: 5 }, (_, i) => (
            <Star
              class:list={[
                "size-5",
                i < 4
                  ? "fill-primary text-primary"
                  : "fill-transparent text-muted-foreground",
              ]}
            />
          ))
        }
      </div>

      {/* Heading */}
      <h3
        class="mb-1 text-lg font-bold text-foreground md:text-xl"
        data-aos="fade-left"
        data-aos-delay="300"
      >
        Loved by 10,000+ Nigerian households
      </h3>

      {/* Quote */}
      <p
        class="text-sm text-muted-foreground md:text-base"
        data-aos="fade-left"
        data-aos-delay="400"
      >
        "T Hazlo changed how I handle home essentials. I don't think twice
        anymore."
      </p>
    </div>
  </div>
</section>
