---
import { Star } from "@lucide/astro"
---

<section class="section-wrapper mx-auto max-w-5xl pb-0">
  <div
    class="flex flex-col items-center justify-center gap-8 sm:flex-row md:gap-10"
  >
    {/* Avatar Stack */}
    <div class="flex -space-x-3" data-aos="zoom-in" data-aos-delay="200">
      <div
        class="flex size-12 items-center justify-center rounded-full border-2 border-background bg-black text-sm font-bold text-white dark:bg-white dark:text-black"
      >
        AB
      </div>
      <div
        class="flex size-12 items-center justify-center rounded-full border-2 border-background bg-[#4BD4FA] text-sm font-bold text-black"
      >
        YB
      </div>
      <div
        class="flex size-12 items-center justify-center rounded-full border-2 border-background bg-[#4CAF50] text-sm font-bold text-black"
      >
        SB
      </div>
    </div>

    {/* Content */}
    <div class="flex flex-col text-center sm:text-left">
      <div
        class="mb-2 flex justify-center gap-1 sm:justify-start"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        {
          Array.from({ length: 5 }, (_, i) => (
            <Star
              class:list={[
                "size-5",
                i < 5
                  ? "fill-primary text-primary"
                  : "fill-transparent text-muted-foreground",
              ]}
            />
          ))
        }
      </div>

      <h3
        class="mb-1 text-lg font-bold text-foreground md:text-xl"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        Loved by 10,000+ Nigerian households
      </h3>

      <p
        class="text-sm text-muted-foreground md:text-base"
        data-aos="fade-up"
        data-aos-delay="400"
      >
        "Thazlo changed how I handle home essentials. I don't think twice
        anymore."
      </p>
    </div>
  </div>
</section>
