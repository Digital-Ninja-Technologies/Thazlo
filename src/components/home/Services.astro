---
import ServiceCard from "@/components/ui/service-card.astro"
import SectionHeader from "@/components/ui/section-header.astro"
import { buttonVariants } from "@/components/ui/button"
import { cn } from "@/lib/utils"

export const servicesData = [
  {
    label: "THAZLO Gas",
    title: "Never run out of gas again",
    description:
      "Order cooking gas refills right from the app. We partner with certified vendors to ensure safe, reliable delivery every time",
    merits: [
      "All cylinder sizes available",
      "Real-time order tracking",
      "Safe, certified vendors only",
      "Pay on delivery supported",
    ],
    cta: "Order Gas",
    isHighlighted: false,
    link: "/download",
  },
  {
    label: "THAZLO Laundry",
    title: "Freshly laundered, every time",
    description:
      "Schedule a pickup, and we return your clothes clean, pressed and ready to wear. No more laundry day stress.",
    merits: [
      "Clothes, bedding, towels & more",
      "Schedule pickup at your convenience",
      "Professional cleaning standards",
      "Doorstep delivery when done",
    ],
    cta: "Order laundry",
    isHighlighted: true,
    link: "/download",
  },
]
---

<section class="section-wrapper" id="services">
  <SectionHeader label="Our Services"> The THAZLO Advantage </SectionHeader>

  <div class="section-body grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-12">
    {
      servicesData.map((service, index) => (
        <div data-aos="fade-up" data-aos-delay={(index + 1) * 150}>
          <ServiceCard {...service} />
        </div>
      ))
    }
  </div>

  <div class="mt-12 flex justify-center md:mt-16">
    <a
      href="/about"
      class={cn(
        buttonVariants({ size: "lg", variant: "outline" }),
        "h-12 border bg-muted/50 dark:bg-muted/10"
      )}>Read more about our services</a
    >
  </div>
</section>
