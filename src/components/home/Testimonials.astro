---
import SectionHeader from "@/components/ui/section-header.astro"
import { Star, Quote, ArrowLeft, ArrowRight } from "@lucide/astro"
import { Button } from "../ui/button"

const testimonials = [
  {
    rating: 4,
    text: "I ordered gas at 8am and it arrived before I left for work. Thazlo has genuinely changed my mornings.",
    author: "Adaeze Femi",
    location: "Lagos Island",
  },
  {
    rating: 4,
    text: "Tracking the delivery in real time gave me so much confidence. This is how every service should work..",
    author: "Chisom Nwosu",
    location: "Victoria Island",
  },
  {
    rating: 4,
    text: "The laundry service is spotless literally. I get my clothes back cleaner than I've ever managed myself..",
    author: "Tunde Kolawole",
    location: "Akure, Ondo State",
  },
]

const sliderItems = [...testimonials, ...testimonials]
---

<section class="section-wrapper relative overflow-hidden">
  <SectionHeader label="Testimonials">
    What customers are saying
  </SectionHeader>

  <div class="section-body relative mt-16">
    {/* Fade Masks for Desktop */}
    <div
      class="pointer-events-none absolute inset-y-0 left-0 z-20 hidden w-16 bg-linear-to-r from-background to-transparent md:block lg:w-32"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-y-0 right-0 z-20 hidden w-16 bg-linear-to-l from-background to-transparent md:block lg:w-32"
    >
    </div>

    {/* Embla Viewport */}
    <div id="testimonial-viewport" class="overflow-hidden py-4">
      {/* Embla Container */}
      <div class="flex touch-pan-y">
        {
          sliderItems.map((review) => (
            <div class="group relative z-10 mx-3 flex w-[320px] shrink-0 snap-center flex-col justify-between overflow-hidden rounded-2xl border border-border bg-card p-8 text-foreground shadow-sm transition-colors duration-200 hover:border-primary hover:bg-primary hover:text-white md:w-100 dark:bg-muted/30 dark:hover:bg-primary">
              {/* Quote Watermark Underlay */}
              <Quote
                class="absolute top-0 right-0 z-0 size-32 -rotate-6 fill-current text-foreground/5 transition-colors duration-300 group-hover:text-white/10 dark:text-white/5"
                stroke="none"
              />

              <div class="relative z-10 mt-12">
                {/* star rating */}
                <div class="mb-6 flex gap-1">
                  {Array.from({ length: 5 }, (_, i) => (
                    <Star
                      class:list={[
                        "size-5 transition-colors duration-300",
                        i < review.rating
                          ? "fill-primary text-primary group-hover:fill-white group-hover:text-white"
                          : "fill-transparent text-muted-foreground group-hover:text-white/50",
                      ]}
                    />
                  ))}
                </div>

                {/* review */}
                <p class="mb-8 text-lg leading-relaxed font-medium text-foreground/90 italic transition-colors duration-300 group-hover:text-white/95">
                  "{review.text}"
                </p>
              </div>

              {/* author details */}
              <div class="relative z-10 mt-auto flex flex-col items-end pt-4 text-right">
                <p class="font-heading font-bold">{review.author}</p>
                <p class="mt-1 text-sm text-muted-foreground transition-colors duration-300 group-hover:text-white/80">
                  {review.location}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Slider Controls */}
    <div class="mt-10 flex items-center justify-center gap-4">
      <Button
        id="btn-prev"
        variant="outline"
        className="rounded-full border border-primary bg-transparent text-primary ring ring-primary/5"
        size="icon-lg"
        aria-label="Previous testimonial"
      >
        <ArrowLeft />
      </Button>
      <Button
        id="btn-next"
        variant="outline"
        className="rounded-full border border-primary bg-transparent text-primary ring ring-primary/5"
        size="icon-lg"
        aria-label="Next testimonial"
      >
        <ArrowRight />
      </Button>
    </div>
  </div>
</section>

<script>
  import EmblaCarousel from "embla-carousel"
  import Autoplay from "embla-carousel-autoplay"

  const setupTestimonialSlider = () => {
    const viewport = document.getElementById("testimonial-viewport")
    const btnPrev = document.getElementById("btn-prev")
    const btnNext = document.getElementById("btn-next")

    if (!viewport || !btnPrev || !btnNext) return

    // Prevent re-initialization
    if (viewport.dataset.initialized === "true") return
    viewport.dataset.initialized = "true"

    const emblaApi = EmblaCarousel(
      viewport,
      {
        loop: true,
        align: "center",
        skipSnaps: false,
      },
      [
        Autoplay({
          delay: 3500, // Slides every 3.5 seconds
          stopOnInteraction: false, // Keeps playing after they manually scroll
          stopOnMouseEnter: true, // Pauses if they hover over a card to read it
        }),
      ]
    )

    btnPrev.addEventListener("click", () => {
      emblaApi.scrollPrev()
      emblaApi.plugins().autoplay.reset() // Reset timer on click so it doesn't jump immediately
    })

    btnNext.addEventListener("click", () => {
      emblaApi.scrollNext()
      emblaApi.plugins().autoplay.reset()
    })
  }

  setupTestimonialSlider()
  document.addEventListener("astro:page-load", setupTestimonialSlider)
</script>
