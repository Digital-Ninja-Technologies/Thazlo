---
import AppImg from "@/assets/image/hero-app.png"
import LogoWatermark from "@/assets/image/logo-watermark.png"
import { Image } from "astro:assets"
import { Star } from "@lucide/astro"
import { StoreButton } from "@/components/ui/store-button"

const rating = 5
---

<section class="relative overflow-hidden pt-16 md:pt-26">
  {/* bg logo */}
  <div
    class="pointer-events-none absolute top-20 left-1/2 z-[-1] -translate-x-1/2 md:top-16"
  >
    <Image
      src={LogoWatermark}
      alt=""
      aria-hidden="true"
      loading="eager"
      priority
      class="h-auto w-100 max-w-none md:w-200"
    />
  </div>

  <div
    class="section-wrapper relative z-10 flex flex-col items-center justify-center space-y-10 pb-8 text-center md:pb-12"
  >
    {/* headings */}
    <div class="max-w-5xl space-y-6">
      <div class="flex flex-wrap justify-center gap-4">
        <span class="badge" data-aos="fade-up" data-aos-delay="100">
          {
            Array.from({ length: rating }, (_, i) => (
              <Star
                class:list={[
                  "size-4 fill-muted text-muted",
                  { "fill-primary text-primary": i < rating },
                ]}
              />
            ))
          }
          <span>{rating.toFixed(1)} Rating</span>
        </span>
        <span class="badge" data-aos="fade-up" data-aos-delay="100">
          24/7 Customer Care
        </span>
      </div>

      <h1 class="section-title" data-aos="fade-up" data-aos-delay="200">
        Get Gas and Laundry Service <br class="hidden md:block" />
        <span class="text-primary">Anytime, Anywhere</span>
      </h1>

      <p
        class="section-description mx-auto"
        data-aos="fade-up"
        data-aos-delay="300"
      >
        <span class="font-medium text-primary">Gas refills</span> delivered to your
        doorstep. <span class="font-medium text-primary">Laundry</span> picked up
        and returned spotless. THAZLO handles the hassle so you don't have to.
      </p>
    </div>

    {/* CTAs */}
    <div
      class="flex flex-wrap items-center justify-center gap-4"
      data-aos="fade-up"
      data-aos-delay="300"
    >
      <StoreButton platform="apple" storeVariant="dark" />
      <StoreButton platform="google" storeVariant="dark" />
    </div>

    {/* badge */}
    <div data-aos="fade-up" data-aos-delay="200">
      <span class="badge">
        <span class="size-2.5 animate-pulse rounded-full bg-primary"></span>
        Now available across Nigeria
      </span>
    </div>

    {/* hero img */}
    <div
      class="w-full max-w-85 md:max-w-100"
      data-aos="fade-up"
      data-aos-delay="300"
    >
      <div class="relative mx-auto overflow-hidden">
        {/* glow */}
        <div
          class="absolute inset-0 z-[-1] bg-linear-to-t from-background via-primary/5 to-transparent"
        >
        </div>

        <Image
          src={AppImg}
          alt="THAZLO app home screen"
          class="h-auto w-full rounded-t-3xl object-cover"
          loading="lazy"
        />

        {/* fade out gradient */}
        <div
          class="absolute right-0 bottom-0 left-0 h-32 bg-linear-to-t from-background to-transparent"
        >
        </div>
      </div>
    </div>
  </div>
</section>
